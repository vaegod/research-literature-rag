# OpenAI-compatible provider, defaulting to SiliconFlow.
APP_VERSION=0.1.0
OPENAI_COMPATIBLE_API_KEY=your_api_key
OPENAI_COMPATIBLE_BASE_URL=https://api.siliconflow.cn/v1
CHAT_MODEL=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Browser/API access. Keep credentials disabled unless a trusted frontend origin is configured.
CORS_ALLOW_ORIGINS=http://127.0.0.1:8010,http://localhost:8010
CORS_ALLOW_CREDENTIALS=false

# Paths
RAW_DOCS_PATH=data/raw_docs
PROCESSED_DOCS_PATH=data/processed_docs
VECTOR_STORE_PATH=vector_store/faiss_index
EXPERIMENT_RECORDS_PATH=data/experiments/experiment_records.json
EVAL_QUESTIONS_PATH=data/eval/rag_eval_questions.csv
EVAL_RESULT_PATH=data/eval/eval_result.csv

# RAG
DEFAULT_TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120
CHAT_TEMPERATURE=0.2
MAX_UPLOAD_SIZE_MB=20

# Retrieval
RETRIEVAL_MODE=hybrid
HYBRID_DENSE_WEIGHT=0.65
HYBRID_BM25_WEIGHT=0.35
HYBRID_RRF_K=60
RETRIEVAL_FETCH_MULTIPLIER=12
RETRIEVAL_MIN_CANDIDATES=60

# Optional SiliconFlow reranker. Keep disabled for local tests; enable for demos.
ENABLE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_CANDIDATE_LIMIT=24
RERANKER_MAX_CHARS=1800
RERANKER_TIMEOUT_SECONDS=30

# FAISS stores metadata through pickle. Only load indexes generated by this project locally.
TRUST_LOCAL_FAISS_INDEX=true

# Agent router: rule by default; set to hybrid or llm to enable optional model routing.
AGENT_ROUTER_MODE=rule
